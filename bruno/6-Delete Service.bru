docs {
  Delete a deployed service and all its Kubernetes resources.
  
  This will remove:
  - Kubernetes Deployment
  - ClusterIP Service
  - Gateway route registration
  
  Expected Response:
  {
    "status": "deleted",
    "service_name": "example-api"
  }
}
